# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# RESEND_API_KEY: API Key for Resend email provider
RESEND_API_KEY=

# RESEND_FROM: From email address for Resend, e.g., "TasksEarn <noreply@tasksearn.com>"
RESEND_FROM=

# SMTP_HOST: SMTP server hostname (e.g., smtp.gmail.com, smtp.mailgun.org, smtp.sendgrid.net)
SMTP_HOST=

# SMTP_PORT: SMTP server port (e.g., 587 or 465)
SMTP_PORT=

# SMTP_USER: SMTP authentication username/email
SMTP_USER=

# SMTP_PASSWORD: SMTP authentication password or App Password / API Key
SMTP_PASSWORD=

# SMTP_FROM: From email address for SMTP, e.g., "TasksEarn <noreply@tasksearn.com>"
SMTP_FROM=

# PAYSTACK_SECRET_KEY: Official secret key for Paystack integrations (starts with sk_live_ or sk_test_)
PAYSTACK_SECRET_KEY=

# PAYSTACK_PUBLIC_KEY: Official public key for Paystack integrations (starts with pk_live_ or pk_test_)
PAYSTACK_PUBLIC_KEY=
